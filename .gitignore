*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.virtualenv/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.tmp
*.temp
logs/

